<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">
    <div class="govuk-grid-column-two-thirds">
      <div class="govuk-grid-row">
        <h1 class="govuk-heading-xl"><%= t('opt_out.incorrect_epc.title') %></h1>

        <p>
          <%=t('opt_out.incorrect_epc.recent.text', link: '<a class="govuk-link" href="' + t('register_find_url') + '">' + t('opt_out.incorrect_epc.recent.cta') + "</a>.") %>
        </p>

        <p>
          <%=t('opt_out.find_epc.text', link: '<a class="govuk-link" href="' + t('register_find_url') + '">' + t('opt_out.find_epc.cta') + "</a>.") %>
        </p>

        <p>
          <%=t('opt_out.incorrect_epc.not_recent.text', link: '<a class="govuk-link" href="' + t('register_get_url') + '">' + t('opt_out.incorrect_epc.not_recent.cta') + "</a>.") %>
        </p>

        <div class="govuk-inset-text">
          <%= t('opt_out.incorrect_epc.note') %>
        </div>
      </div>

    </div>
  </div>
</div>
