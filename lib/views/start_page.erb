<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <div>
      <h1 class="govuk-heading-xl"><%=t('service_name') %></h1>

      <p>
        <%=t('start_page.service_for') %>
      </p>

      <ul class="govuk-list govuk-list--bullet">
        <li><%=t('start_page.domestic') %></li>
        <li><%=t('start_page.non_domestic') %></li>
        <li><%=t('start_page.public_buildings') %></li>
      </ul>

      <p>
        <%=t('start_page.visit_register.visit', link: '<a class="govuk-link" href="' + t('register_find_url') + '">' + t('start_page.visit_register.cta') + "</a>.") %>
      </p>

      <p>
        <%=t('start_page.visit_scottish_register.visit', link: '<a class="govuk-link" href="' + t('start_page.visit_scottish_register.url') + '">' + t('start_page.visit_scottish_register.cta') + "</a>.") %>
      </p>

      <p>
        <%=t('start_page.expired_replaced') %>
      </p>
    </div>

    <div>
      <h2 class="govuk-heading-m govuk-!-padding-top-2">
        <%=t('start_page.how_to_use.heading') %>
      </h2>

      <p>
        <%=t('start_page.how_to_use.use') %>
      </p>

      <ul class="govuk-list govuk-list--bullet">
        <li><%=t('start_page.how_to_use.csv') %></li>
        <li><%=t('start_page.how_to_use.api') %></li>
      </ul>

      <p>
        <%=t('start_page.how_to_use.need_cert', link: '<a class="govuk-link" href="' + t('register_find_url') + '">' + t('start_page.visit_register.cta') + "</a>.") %>
      </p>
    </div>

    <div>
      <h2 class="govuk-heading-m govuk-!-padding-top-2">
        <%=t('start_page.what_you_will_need.heading') %>
      </h2>

      <p>
        <%=t('start_page.what_you_will_need.one_login') %>
      </p>

      <a
        href="/data-access-options"
        role="button"
        draggable="false"
        class="govuk-button govuk-button--start govuk-!-margin-top-2 govuk-!-margin-bottom-8"
        data-module="govuk-button">
        <%=t('start_page.what_you_will_need.cta') %>
        <svg
          class="govuk-button__start-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="17.5"
          height="19"
          viewBox="0 0 33 40"
          role="presentation"
          focusable="false">
          <path fill="currentColor" d="M0 0h13l20 20-20 20H0l20-20z"></path>
        </svg>
      </a>
    </div>
  </div>
</div>
<div class="govuk-grid-row">
  <%= erb :component__get_help %>
</div>